# Rails
RAILS_ENV=development
SECRET_KEY_BASE=generate-with-rails-secret

# Database (Railway provides this automatically in production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vibe_development

# JWT (set via rails credentials:edit)
# jwt_secret is stored in encrypted credentials, not here

# AWS Bedrock (AI models)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Model overrides (optional — defaults to Haiku/Sonnet via Bedrock)
# MODEL_PROMPT_ENHANCER=anthropic.claude-3-haiku-20240307-v1:0
# MODEL_PLANNER=anthropic.claude-3-haiku-20240307-v1:0
# MODEL_GENERATOR=anthropic.claude-3-5-sonnet-20241022-v2:0
# MODEL_ERROR_INTERPRETER=anthropic.claude-3-haiku-20240307-v1:0
# MODEL_EDIT=anthropic.claude-3-haiku-20240307-v1:0

# Firebase
FIREBASE_PROJECT_ID=vibe-development
FIREBASE_SERVICE_ACCOUNT_KEY=

# Google Cloud Storage
GCS_PROJECT_ID=
GCS_CREDENTIALS_JSON=
GCS_BUCKET_BUNDLES=vibe-app-bundles
GCS_BUCKET_THUMBNAILS=vibe-thumbnails
GCS_BUCKET_AVATARS=vibe-avatars

# Playwright validator sidecar
VALIDATOR_SERVICE_URL=http://localhost:3001

# Sentry (optional for development)
# SENTRY_DSN=

# Amplitude (optional for development)
# AMPLITUDE_API_KEY=

# Expo push notifications (optional for development)
# EXPO_ACCESS_TOKEN=

# Slack alerting (optional for development)
# SLACK_WEBHOOK_URL=
